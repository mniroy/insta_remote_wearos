<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <com.arashivision.sdkmedia.player.capture.InstaCapturePlayerView
        android:id="@+id/capture_player_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:background="#777777" />


    <com.arashivision.sdk.demo.view.ByteBufferArgbGLSurfaceView
        android:id="@+id/surface_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/tag_view"
        app:layout_constraintEnd_toEndOf="@+id/tag_view"
        app:layout_constraintStart_toStartOf="@+id/tag_view"
        app:layout_constraintTop_toTopOf="@+id/tag_view" />

    <TextView
        android:id="@+id/not_support_preview"
        style="@style/TextStyle.Main.White"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:text="@string/capture_preview_not_supported"
        android:textSize="25sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_remaining"
        style="@style/TextStyle.Main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="44dp"
        android:gravity="start"
        android:lineHeight="20dp"
        android:maxWidth="180dp"
        android:padding="6dp"
        android:textColor="@color/red"
        android:textSize="14sp"
        android:visibility="visible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="可录制20分钟" />

    <View
        android:id="@+id/tag_view"
        android:layout_width="144dp"
        android:layout_height="256dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.arashivision.sdk.demo.view.discretescrollview.DiscreteScrollView
        android:id="@+id/sv_capture_mode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:foregroundGravity="center"
        android:overScrollMode="never"
        app:dsv_orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.arashivision.sdk.demo.view.CaptureShutterButton
        android:id="@+id/btn_capture"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_capture_normal"
        app:layout_constraintBottom_toTopOf="@+id/sv_capture_mode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:background="@drawable/ic_capture_shutter_record_idle" />

    <ImageView
        android:id="@+id/iv_capture_highlight"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="36dp"
        android:padding="6dp"
        android:visibility="gone"
        tools:visibility="visible"
        android:src="@drawable/ic_capture_highlight"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_capture_setting"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="36dp"
        android:src="@drawable/ic_capture_setting"
        app:layout_constraintBottom_toBottomOf="@+id/btn_capture"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_capture" />

    <TextView
        android:id="@+id/tv_record_time"
        style="@style/TextStyle.Main.White"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@+id/btn_capture"
        app:layout_constraintEnd_toStartOf="@+id/iv_arrow"
        app:layout_constraintStart_toStartOf="@+id/btn_capture"
        tools:text="10:00:36" />

    <ImageView
        android:id="@+id/iv_arrow"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_double_arrow_right"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/tv_video_duration"
        app:layout_constraintEnd_toStartOf="@+id/tv_video_duration"
        app:layout_constraintStart_toEndOf="@+id/tv_record_time"
        app:layout_constraintTop_toTopOf="@+id/tv_video_duration" />

    <TextView
        android:id="@+id/tv_video_duration"
        style="@style/TextStyle.Main.White"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/btn_capture"
        app:layout_constraintEnd_toEndOf="@+id/btn_capture"
        app:layout_constraintStart_toEndOf="@+id/iv_arrow"
        tools:text="10:00:36" />


    <com.arashivision.sdk.demo.view.picker.PickerView
        android:id="@+id/pick_capture_setting"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/dialog_bg_color"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>